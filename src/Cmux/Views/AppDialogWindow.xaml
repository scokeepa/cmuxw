<Window x:Class="Cmux.Views.AppDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Dialog"
        Height="220"
        Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="{StaticResource WindowCornerRadius}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="4"
                              Color="#000000"
                              Opacity="0.4"
                              Direction="270" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    CornerRadius="10,10,0,0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock x:Name="TitleText"
                               Text="Dialog"
                               Foreground="{DynamicResource ForegroundDimBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0" />
                    <Button Style="{StaticResource WindowCloseButton}"
                            HorizontalAlignment="Right"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="CloseButton_Click"
                            Width="38"
                            Height="32">
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="9" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="IconBadge"
                            Width="32"
                            Height="32"
                            CornerRadius="16"
                            Background="{DynamicResource SidebarItemHoverBrush}"
                            VerticalAlignment="Top"
                            Margin="0,0,12,0">
                        <TextBlock x:Name="IconGlyph"
                                   Text="&#xE946;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AccentBrush}" />
                    </Border>

                    <TextBlock x:Name="MessageText"
                               Grid.Column="1"
                               Foreground="{DynamicResource ForegroundBrush}"
                               TextWrapping="Wrap"
                               FontSize="13" />
                </Grid>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,12,0,0">
                    <Button x:Name="TertiaryButton"
                            Visibility="Collapsed"
                            Style="{StaticResource CmuxButton}"
                            Padding="12,6"
                            Margin="0,0,8,0"
                            Click="TertiaryButton_Click" />
                    <Button x:Name="SecondaryButton"
                            Visibility="Collapsed"
                            Style="{StaticResource CmuxButton}"
                            Padding="12,6"
                            Margin="0,0,8,0"
                            Click="SecondaryButton_Click" />
                    <Button x:Name="PrimaryButton"
                            Style="{StaticResource AccentButton}"
                            Padding="14,6"
                            Click="PrimaryButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
